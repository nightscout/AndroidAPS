    <!-- DoubleKey: APS preferences -->
    <string name="pref_title_max_basal">Maximální bazální dávka</string>
    <string name="openapsma_max_basal_summary">Tato hodnota se v kontextu OpenAPS nazývá max basal</string>
    <string name="pref_title_smb_max_iob">Max IOB pro SMB</string>
    <string name="openapssmb_max_iob_summary">Tato hodnota se v kontextu OpenAPS nazývá Max IOB\nOpenAPS nepřidá více inzulínu, pokud je aktuální IOB větší než tato hodnota</string>
    <string name="pref_title_ama_max_iob">Max IOB pro AMA</string>
    <string name="openapsma_max_iob_summary">Tato hodnota se v kontextu OpenAPS nazývá Max IOB\nToto je maximální množství inzulínu [U], které APS může najednou podat.</string>
    <string name="pref_title_max_daily_multiplier">Maximální denní bezpečnostní násobitel</string>
    <string name="openapsama_max_daily_safety_multiplier_summary">Výchozí hodnota: 3. Jde o klíčový bezpečnostní limit OpenAPS. Omezuje vaše bazály na 3násobek vašeho nejvyššího bazálu. Pravděpodobně nebudete potřebovat tuto hodnotu měnit, ale měli byste vědět, že právě toto je míněno v diskuzi o bezpečnostních limitech „3× max denní; 4× aktuální“.</string>
    <string name="pref_title_current_basal_multiplier">Aktuální bezpečnostní násobitel bazálu</string>
    <string name="openapsama_current_basal_safety_multiplier_summary">Výchozí hodnota: 4. Jde o druhou polovinu klíčových bezpečnostních limitů OpenAPS a druhou polovinu limitů „3× max denní; 4× aktuální“. Znamená to, že váš bazál bez ohledu na max. bazál nastavený v pumpě nemůže být vyšší než tento násobek aktuální úrovně vašeho bazálu. Cílem je zabránit tomu, aby se lidé dostali do nebezpečné oblasti nastavením příliš vysokých max. bazálů bez pochopení, jak algoritmus funguje. Výchozí hodnota je opět 4×; většina uživatelů ji nikdy nebude potřebovat měnit, a spíše bude třeba upravit jiná nastavení, pokud mají pocit, že do tohoto bezpečnostního limitu „narážejí“.</string>
    <string name="pref_title_bolus_snooze_divisor">Dělitel bolus snooze DIA</string>
    <string name="openapsama_bolus_snooze_dia_divisor_summary">Výchozí hodnota: 2\nBolus snooze se aktivuje poté, co si dáte jídelní bolus, aby smyčka neprotiběhla nízkými dočasnými bazály, když jste právě jedli. Příklad zde a výchozí hodnota je 2; takže 3hodinová DIA znamená, že bolus snooze bude postupně utlumen v průběhu 1,5 hodiny (3DIA/2).</string>
    <string name="pref_title_ama_min_5m_carbs_impact">AMA min 5m dopad sacharidů</string>
    <string name="pref_title_smb_min_5m_carbs_impact">SMB min 5m dopad sacharidů</string>
    <string name="openapsama_min_5m_carb_impact_summary">Výchozí hodnota: 3.0 (AMA) nebo 8.0 (SMB). Toto je nastavení pro výchozí dopad absorpce sacharidů za 5 minut. Výchozí očekávaný je 3 mg/dl/5 min. Ovlivňuje, jak rychle se COB snižuje a jaká absorpce sacharidů se předpokládá při výpočtu budoucí predikované glykémie, když glykémie klesá více, než se očekávalo, nebo neroste tolik, jak se očekávalo.</string>
    <string name="pref_title_absorption_cutoff">Doba absorpce</string>
    <string name="absorption_cutoff_summary">Čas, po kterém je jakékoli jídlo považováno za absorbované. Zbylé sacharidy budou odříznuty.</string>
    <string name="pref_title_absorption_maxtime">Maximální doba absorpce</string>
    <string name="absorption_max_time_summary">Čas v hodinách, kdy se očekává absorbování všech sacharidů z jídla</string>
    <string name="pref_title_autosens_min">Autosens min</string>
    <string name="openapsama_autosens_min_summary">Výchozí hodnota: 0,7\nDruhá strana bezpečnostních limitů Autosens, stanovuje dolní mez, jak nízko může Autosens upravit bazály a jak vysoko může upravit ISF a cíle glykémie.</string>
    <string name="pref_title_autosens_max">Autosens max</string>
    <string name="openapsama_autosens_max_summary">Výchozí hodnota: 1,2\nJde o násobící strop pro Autosens (a brzy i Autotune), který nastavuje maximální limit 20%% na to, jak vysoko může být poměr Autosens, což zase určuje, jak vysoko může Autosens upravit bazály, jak nízko může upravit ISF a jak nízko může nastavit cíl glykémie.</string>
    <string name="pref_title_autoisf_min">AutoISF min</string>
    <string name="openapsama_autoISF_min_summary">Podobně jako autosens_min definuje, jak slabé může ISF být.\n\nVýchozí hodnota 1,0 tento efekt efektivně vypíná.</string>
    <string name="pref_title_autoisf_max">AutoISF max</string>
    <string name="openapsama_autoISF_max_summary">Podobně jako autosens_max definuje, jak silné může ISF být.\n\nVýchozí hodnota 1,0 tento efekt efektivně vypíná.\n\nUPOZORNĚNÍ: Buďte extrémně opatrní při použití hodnot nad 2,5.</string>
    <string name="pref_title_bg_accel_weight">Váha ISF při zrychlení glykémie</string>
    <string name="openapsama_bgAccel_ISF_weight_summary">Toto je váha uplatněná při zrychlování glykémie, která zesiluje ISF a může tak zvýšit podávání inzulínu.\n\nVýchozí hodnota 0,0 tento efekt efektivně vypíná.</string>
    <string name="pref_title_bg_brake_weight">Váha ISF při zpomalení glykémie</string>
    <string name="openapsama_bgBrake_ISF_weight_summary">Toto je váha uplatněná při zpomalování glykémie, která oslabuje ISF a může tak snížit podávání inzulínu.\n\nVýchozí hodnota 0,0 tento efekt efektivně vypíná.</string>
    <string name="pref_title_low_bg_weight">Váha v nízkém rozsahu glykémie</string>
    <string name="openapsama_lower_ISFrange_weight_summary">Toto je váha uplatněná, když je glykémie pod cílem, která oslabuje ISF a může tak snížit podávání inzulínu.\n\nVýchozí hodnota 0,0 tento efekt efektivně vypíná.</string>
    <string name="pref_title_high_bg_weight">Váha ve vysokém rozsahu glykémie</string>
    <string name="openapsama_higher_ISFrange_weight_summary">Toto je váha uplatněná, když je glykémie nad cílem, která zesiluje ISF a může tak zvýšit podávání inzulínu.\n\nVýchozí hodnota 0,0 tento efekt efektivně vypíná.</string>
    <string name="pref_title_smb_delivery_ratio_bg_range">Rozsah glykémie pro poměr podávání SMB</string>
    <string name="openapsama_smb_delivery_ratio_bg_range_summary">Výchozí hodnota: 0. Lineárně rostoucí poměr SMB je namapován na rozsah glykémie [target_bg, target_bg+bg_range].\nPři target_bg je poměr SMB roven smb_delivery_ratio_min, při target_bg+bg_range je roven smb_delivery_ratio_max.\nHodnota 0 vypíná lineárně rostoucí poměr SMB a používá se pevná hodnota smb_delivery_ratio.</string>
    <string name="pref_title_pp_weight">Post-prandiální váha ISF</string>
    <string name="openapsama_pp_ISF_weight_summary">Toto je váha uplatněná, když glykémie stoupá, která zesiluje ISF a může tak zvýšit podávání inzulínu.\n\nVýchozí hodnota 0,0 tento efekt efektivně vypíná.</string>
    <string name="pref_title_dura_weight">Váha ISF podle trvání</string>
    <string name="openapsama_dura_ISF_weight_summary">Toto je váha uplatněná během déletrvajících zvýšených plateau glykémie, která zesiluje ISF a může tak zvýšit podávání inzulínu.\n\nVýchozí hodnota 0,0 tento efekt efektivně vypíná.</string>
    <string name="pref_title_smb_delivery_ratio">Poměr podávání SMB</string>
    <string name="openapsama_smb_delivery_ratio_summary">Výchozí hodnota: 0.5. Toto je další klíčové bezpečnostní omezení OpenAPS a určuje, jaký podíl z celkového potřebného inzulínu lze podat jako SMB. Toto má zabránit uživatelům dostat se do nebezpečné oblasti nastavováním SMB požadavků z telefonu pečovatele současně. Tuto experimentální hodnotu zvyšujte pomalu a s opatrností.</string>
    <string name="pref_title_smb_delivery_ratio_min">Min poměr podávání SMB</string>
    <string name="openapsama_smb_delivery_ratio_min_summary">Výchozí hodnota: 0.5. Toto je spodní konec lineárně rostoucího poměru namísto pevné hodnoty výše.</string>
    <string name="pref_title_smb_delivery_ratio_max">Max poměr podávání SMB</string>
    <string name="openapsama_smb_delivery_ratio_max_summary">Výchozí hodnota: 0.5. Toto je horní konec lineárně rostoucího poměru namísto pevné hodnoty výše.</string>
    <string name="pref_title_smb_max_range_extension">SMB max rozšíření rozsahu</string>
    <string name="openapsama_smb_max_range_extension_summary">Výchozí hodnota: 1. Toto je další klíčové bezpečnostní omezení OpenAPS a určuje, o jaký faktor můžete překročit běžných 120 minut maxSMB/maxUAM. Tuto experimentální hodnotu zvyšujte pomalu a s opatrností.</string>
