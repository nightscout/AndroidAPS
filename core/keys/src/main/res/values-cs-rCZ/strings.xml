    <!-- UnitDoubleKey: APS preferences -->
    <string name="pref_title_lgs_threshold">Práh LGS</string>
    <string name="lgs_threshold_summary">Hodnota glykémie, pod kterou je pozastaven inzulín. Výchozí hodnota používá standardní model cíle. Uživatel může nastavit hodnotu mezi 60 mg/dl (3,3 mmol/l) a 100 mg/dl (5,5 mmol/l). Hodnoty pod 65/3,6 způsobí použití výchozího modelu</string>
