    <string name="pref_title_high_mark">Limit vysokej glykémie</string>
    <!-- UnitDoubleKey: APS preferences -->
    <string name="pref_title_lgs_threshold">Prah LGS</string>
    <string name="lgs_threshold_summary">Hodnota glykémie, pod ktorú  bude podávanie inzulínu zastavené. Východzia hodnota využíva štandardný cieľový model. Užívateľ môže nastaviť hodnoty od 3,3 mmol/l do 5,5 mmol/l. Pri hodnotách pod 3,6 mmol/l se použije východzí model.</string>
