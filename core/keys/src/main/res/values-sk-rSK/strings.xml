    <!-- DoubleKey: APS preferences -->
    <string name="pref_title_max_basal">Maximálna bazálna dávka</string>
    <string name="openapsma_max_basal_summary">Táto hodnota je v kontexte OpenAPS nazývaná ako \"max basal\"</string>
    <string name="pref_title_smb_max_iob">Max IOB pre SMB</string>
    <string name="openapssmb_max_iob_summary">Táto hodnota sa v kontexte\nOpenAPS nazýva Max IOB. OpenAPS nepridá viac inzulínu, ak je aktuálny IOB vyšší ako táto hodnota. Hodnotu ovplyvňuje aj typ pacienta.</string>
    <string name="pref_title_ama_max_iob">Max IOB pre AMA</string>
    <string name="openapsma_max_iob_summary">Táto hodnota sa v kontexte OpenAPS nazýva Max IOB\n. Toto je maximálne množstvo inzulínu v [U], ktoré dokáže APS podať naraz. Hodnotu ovplyvňuje aj typ pacienta.</string>
    <string name="pref_title_max_daily_multiplier">Maximálny bezpečnostný násobiteľ najvyššieho denného bazálu</string>
    <string name="openapsama_max_daily_safety_multiplier_summary">Štandardná hodnota: 3 Toto je kľúčová hodnota zabezpečenia. Hovorí, že maximálny nastaviteľný bazál je trojnásobkom maximálneho denného bazálu. Spravidla to zrejme nebudete musieť meniť, prípadne si prečítate o téme bezpečnostných limitov \"3x max denný; 4x aktuálny\".</string>
    <string name="pref_title_current_basal_multiplier">Bezpečnostný násobiteľ aktuálneho bazálu</string>
    <string name="openapsama_current_basal_safety_multiplier_summary">Východzia hodnota: 4. Ide o druhú polovicu kľúčových bezpečnostných limitov OpenAPS a druhú polovicu limitov „3× max denný 4× aktuálny“. Znamená to, že váš bazál bez ohľadu na max. bazál nastavený v pumpe nemôže byť vyšší ako tento násobok aktuálnej úrovne vášho bazálu. Cieľom je zabrániť tomu, aby sa ľudia dostali do nebezpečnej oblasti nastavením príliš vysokých max. bazálov bez pochopenia, ako algoritmus funguje. Východzia hodnota je znova 4×; väčšina požívateľov ju nikdy nebude potrebovať meniť. Najskôr bude potrebné upraviť iné nastavenia, pokiaľ majú pocit, že do tohto bezpečnostného limitu „narážajú“.</string>
    <string name="pref_title_bolus_snooze_divisor">Deliteľ bolus snooze DIA</string>
    <string name="openapsama_bolus_snooze_dia_divisor_summary">Štandardná hodnota: 2\nBolus snooze sa aktivuje vtedy, keď je podaný bolus na jedlo, aby uzavretý okruh nereagoval, ak ste práve jedli. Napríklad tu je štandardná hodnota 2;  3 hodinová DIA znamená, že bolus snooze bude postupne utlmovaný v priebehu 1,5 hodiny (3DIA/2).</string>
    <string name="pref_title_ama_min_5m_carbs_impact">AMA min 5m vplyv sacharidov </string>
    <string name="pref_title_smb_min_5m_carbs_impact">SMB min 5m dopad sacharidov</string>
    <string name="openapsama_min_5m_carb_impact_summary">Štandardná hodnota: 3.0 (AMA), alebo 8.0 (SMB). Prednastavená je 3 mg/dl/5min. Táto hodnota definuje minimálnu časť absorbovaných (vstrebaných) sacharidov za každých 5min. Táto hodnota ovplyvňuje výpočet COB. Ovplyvňuje to, ako rýchlo sa COB znižuje a aká absorbcia sacharidov je očakávaná pri výpočte budúcej predpokladanej glykémie, keď klesá alebo narastá viac ako sa očakávalo.</string>
    <string name="pref_title_absorption_cutoff">Doba absorbcie (vstrebávania)</string>
    <string name="absorption_cutoff_summary">Čas, po ktorom je akékoľvek jedlo považované za absorbované (vstrebané). Zvyšné sacharidy budú vynulované.</string>
    <string name="pref_title_absorption_maxtime">Maximálna doba absorpcie (vstrebávania)</string>
    <string name="absorption_max_time_summary">Čas v hodinách, počas ktorého sa predpokladá, že všetky sacharidy budú absorbované (vstrebané).</string>
    <string name="pref_title_autosens_min">Autosens min</string>
    <string name="openapsama_autosens_min_summary">Štandardná hodnota: 0.7\nToto je bezpečnostné nastavenie pre automatickú detekciu citlivosti. Hovorí, že automatická detekcia citlivosti môže znížiť bazály, zvýšiť ISF (citlivosť) a zvýšiť cieľovú hodnotu glykémie.</string>
    <string name="pref_title_autosens_max">Autosens max</string>
    <string name="openapsama_autosens_max_summary">Štandardná hodnota: 1,2\n Ide o maximálny násobok pre Autosens (a čoskoro aj Autotune), ktorý nastavuje maximálny limit 20%% na to, aký vysoký môže byť pomer Autosens. Toto určuje aj to, ako vysoko môže Autosens upraviť bazály, ako nízko môže upraviť ISF a ako nízko môže nastaviť cieľ glykémie.</string>
    <string name="pref_title_autoisf_min">AutoISF min</string>
    <string name="openapsama_autoISF_min_summary">Podobne ako autosens_min definuje, aké slabé môže byť ISF.\n\nVýchozia hodnota 1.0 túto funkciu vypne.</string>
    <string name="pref_title_autoisf_max">AutoISF max</string>
    <string name="openapsama_autoISF_max_summary">Podobne ako autosens_max, toto definuje, aké silné môže byť ISF.\n\nPredvolená hodnota 1,0 túto funkciu vypne.\n\nUPOZORNENIE: Pri používaní hodnôt nad 2,5 je potrebné byť veľmi opatrný</string>
    <string name="pref_title_bg_accel_weight">Váha ISF pri zrýchlení zmeny glykémie</string>
    <string name="openapsama_bgAccel_ISF_weight_summary">Toto je váha ktorá je aplikovaná v situácii, keď je glykémia nad cieľovou hodnotou a parameter, ktorý znižuje ISF, čím potenciálne zvyšuje podávanie inzulínu.\n\nPredvolená hodnota 0.0 túto funkciu vypne.</string>
    <string name="pref_title_bg_brake_weight">Váha ISF pri spomalení zmeny glykémie</string>
    <string name="openapsama_bgBrake_ISF_weight_summary">Toto je váha, ktorá je aplikovaná pri spomaľovaní vzostupu glykémie a parameter, ktorý zvyšuje ISF, čím potenciálne znižuje množstvo dodaného inzulínu.\n\nPredvolená hodnota 0.0 túto funkciu vypne.</string>
    <string name="pref_title_low_bg_weight">Váha v nízkom rozsahu glykémie</string>
    <string name="openapsama_lower_ISFrange_weight_summary">Toto je váha, ktorá je aplikovaná v situácii, keď je glykémia pod cieľovou hodnotou a parameter, ktorý zvyšuje ISF, čím potenciálne znižuje množstvo dodaného inzulínu.\n\nPredvolená hodnota 0.0 túto funkciu vypne.</string>
    <string name="pref_title_high_bg_weight">Váha vo vysokom rozsahu glykémie</string>
    <string name="openapsama_higher_ISFrange_weight_summary">Toto je váha, ktorá je aplikovaná v situácii, keď je glykémia nad cieľovou hodnotou a parameter, ktorý znižuje ISF, čím potenciálne zvyšuje podávanie inzulínu.\n\nPredvolená hodnota 0.0 túto funkciu vypne.</string>
    <string name="pref_title_smb_delivery_ratio_bg_range">Rozsah glykémie pre pomer podávania SMB</string>
    <string name="openapsama_smb_delivery_ratio_bg_range_summary">Štandardná hodnota: 0. Lineárne narastajúca veľkosť SMB je naviazaná na rozsah glykémie [target_bg, target_bg+bg_range].\nPri target_bg veľkosť SMB zodpovedá smb_delivery_ratio_min, pri target_bg+bg_range zodpovedá smb_delivery_ratio_max\nPri hodnote 0 je lineárne narastajúca veľkosť SMB vypnutá a používa sa pevná hodnota smb_delivery_ratio.</string>
    <string name="pref_title_pp_weight">Post-prandiálna váha ISF</string>
    <string name="openapsama_pp_ISF_weight_summary">Toto je váha, ktorá je aplikovaná, keď glykémia stúpa a parameter, ktorý znižuje ISF, čím potenciálne zvyšuje množstvo dodaného inzulínu.\n\nPredvolená hodnota 0.0 túto funkciu vypne.</string>
    <string name="pref_title_dura_weight">Váha ISF podľa trvania</string>
    <string name="openapsama_dura_ISF_weight_summary">Toto je váha, ktorá je aplikovaná pri dlhotrvajúcej hyperglykémii a parameter, ktorý znižuje ISF, čím potenciálne zvyšuje množstvo dodaného inzulínu.\n\nPredvolená hodnota 0.0 túto funkciu vypne.</string>
    <string name="pref_title_smb_delivery_ratio">Pomer podávania SMB</string>
    <string name="openapsama_smb_delivery_ratio_summary">Štandardná hodnota: 0.5 Toto je ďalšie dôležité bezpečnostné nastavenie OpenAPS, ktoré určuje, aké percento celkového inzulínu je možné vydať prostredníctvom SMB. Jeho zmyslom je zabrániť tomu, aby sa užívatelia vystavili riziku kvôli tomu, že by požiadavka na SMB odišla v tej istej chvíli prostredníctvom telefónu. Zvyšujte túto experimentálnu hodnotu pomaly a opatrne.</string>
    <string name="pref_title_smb_delivery_ratio_min">Min pomer podávania SMB</string>
    <string name="openapsama_smb_delivery_ratio_min_summary">Štandardná hodnota: 0.5 Toto je spodný limit lineárne narastajúcej veľkosti, skôr než fixné zvýšenie.</string>
    <string name="pref_title_smb_delivery_ratio_max">Max pomer podávania SMB</string>
    <string name="openapsama_smb_delivery_ratio_max_summary">Štandardná hodnota: 0.5 Toto je horný limit lineárne narastajúcej veľkosti, skôr než fixné zvýšenie.</string>
    <string name="pref_title_smb_max_range_extension">SMB max rozšírenie rozsahu</string>
    <string name="openapsama_smb_max_range_extension_summary">Štandardná hodnota: 1. Toto je ďalší dôležitý bezpečnostný limit OpenAPS a špecifikuje, nakoľko môžete prekročiť štandardný limit 120 minút pre maxSMB/maxUAM. Zvyšujte túto experimentálnu hodnotu pomaly a opatrne.</string>
