    <string name="pref_title_lgs_threshold">LGS-terskel</string>
    <string name="lgs_threshold_summary">BS-verdien som insulinet stanses under. Standardverdien bruker standard målmodell. Brukeren kan angi verdi mellom 60 mg/dL (3,3 mmol/L) og 100 mg/dL (5,5 mmol/L). Verdier under 65/3,6 resulterer i bruk av standardmodellen.</string>
