    <string name="pref_summary_use_super_bolus">Aktiverer superbolus som leverer insulin raskere ved å låne fra basal.</string>
    <!-- Pump preferences -->
    <string name="pref_title_bt_watchdog">Bluetooth-overvåker</string>
    <string name="pref_summary_bt_watchdog">Slår av Bluetooth i ett sekund hvis tilkobling til pumpen feiler. Kan hjelpe på enkelte telefoner.</string>
