    <string name="pref_title_max_basal">Maksimal basaldose</string>
    <string name="openapsma_max_basal_summary">Denne verdien kalles maks basal i OpenAPS-sammenheng</string>
    <string name="pref_title_smb_max_iob">Maks IOB for SMB</string>
    <string name="pref_title_ama_max_iob">Maks IOB for AMA</string>
    <string name="pref_title_max_daily_multiplier">Maks daglig sikkerhetsmultiplikator</string>
    <string name="openapsama_max_daily_safety_multiplier_summary">Standardverdi: 3 Dette er en grunnleggende sikkerhetsfunksjon i OpenAPS. Den begrenser basalraten til å være 3x den høyeste basalraten fra profilen. Du vil sannsynligvis ikke trenge å endre denne innstillingen, men du bør være klar over at det er dette som diskuteres som \"3x daglig; 4x nåværende\" som sikkerhetsfunksjoner.</string>
    <string name="pref_title_current_basal_multiplier">Nåværende basal sikkerhetsmultiplikator</string>
    <string name="openapsama_current_basal_safety_multiplier_summary">Standardverdi: 4. Dette er den andre halvdelen av de viktige sikkerhetsbegrensningene i OpenAPS, “3x maks daglig; 4x nåværende”. Dette betyr at din midlertidige basaldose, uavhengig av maks basal som er satt på pumpen din, ikke kan være høyere enn dette tallet ganger det nåværende nivået på din profils basaldose. Dette er for å hindre at brukere havner i farlige situasjoner ved å sette altfor høye maks basaler før de forstår hvordan algoritmen fungerer. Igjen, standardverdien er 4x; de fleste trenger aldri å endre dette, og vil heller måtte justere andre innstillinger hvis de føler at de “stanger mot” denne sikkerhetsgrensen.</string>
    <string name="pref_title_bolus_snooze_divisor">Bolus snooze DIA-divisor</string>
    <string name="openapsama_bolus_snooze_dia_divisor_summary">Standard verdi: 2\nBolus-slumre er aktivt etter at du har gitt en måltidsbolus slik at loop ikke skal forsøke å sette lav-temp når du nettopp har spist. I dette eksempelet brukes standardverdi på 2, så med en DIA på 3 timer vil bolus-slumre begrensningen gradvis forsvinne etter 1.5 timer (3DIA / 2).</string>
    <string name="pref_title_ama_min_5m_carbs_impact">AMA min 5 min karboabsorpsjonsvirkning</string>
    <string name="pref_title_smb_min_5m_carbs_impact">SMB min 5 min karboabsorpsjonsvirkning</string>
    <string name="openapsama_min_5m_carb_impact_summary">Standardverdi: 3.0 (AMA) eller 8.0 (SMB). Dette er en innstilling for standard karboabsorpsjonsvirkning per 5 minutter. Standard forventet er 3mg/dl/5min. Dette påvirker hvor raskt COB avtar, og hvor mye karboabsorpsjon antas ved beregning av fremtidig forventet BS, når BS faller mer enn forventet, eller når det ikke stiger så mye som forventet.</string>
    <string name="pref_title_absorption_cutoff">Absorpsjonsgrense</string>
    <string name="absorption_cutoff_summary">Tid der et måltid anses som absorbert. Gjenværende karbo vil bli fjernet.</string>
    <string name="pref_title_absorption_maxtime">Maks absorpsjonstid</string>
    <string name="absorption_max_time_summary">Tid i timer der alle karbo fra et måltid forventes å være absorbert</string>
    <string name="pref_title_autosens_min">Autosens minimum</string>
    <string name="openapsama_autosens_min_summary">Standardverdi: 0.7\nDette er en multiplikatorbegrensning for Autosens-sikkerhet. Den begrenser Autosens til å redusere basalverdier, og øke isulinssensitivitet (ISF) og BS-mål med ikke mer enn enn 30%.</string>
    <string name="pref_title_autosens_max">Autosens maksimum</string>
    <string name="openapsama_autosens_max_summary">Standardverdi: 1.2\nDette er en multiplikatorbegrensning for Autosens (og snart Autotune) som begrenser at Autosens ikke kan øke med mer enn 20%%, som dermed begrenser hvor mye Autosens kan justere opp dine basaler, hvor mye ISF kan reduseres og hvor lavt BS-målverdi kan settes.</string>
    <string name="pref_title_autoisf_min">AutoISF minimum</string>
    <string name="openapsama_autoISF_min_summary">På samme måte som autosens_min definerer dette hvor svak ISF kan bli.\n\nStandardverdien 1.0 demper effektivt denne effekten.</string>
    <string name="pref_title_autoisf_max">AutoISF maksimum</string>
    <string name="openapsama_autoISF_max_summary">På samme måte som autosens_max definerer dette hvor sterk ISF kan bli.\n\nStandardverdien 1.0 skrur effekten effektivt av.\n\nADVARSEL: Vær ekstremt forsiktig når du bruker verdier over 2.5</string>
    <string name="pref_title_bg_accel_weight">BS-akselerasjon ISF-vekt</string>
    <string name="openapsama_bgAccel_ISF_weight_summary">Dette er vekten som tillegges når glukosen akselererer og som styrker ISF og dermed potensielt øker insulinleveransen.\n\nStandardverdien 0.0 skrur effektivt av denne effekten.</string>
    <string name="pref_title_bg_brake_weight">BS-bremsing ISF-vekt</string>
    <string name="openapsama_bgBrake_ISF_weight_summary">Dette er vekten som tillegges når glukosen er deakselererer og svekker ISF og dermed potensielt reduserer insulinleveransen.\n\nStandardverdien 0.0 skrur effektivt av denne effekten.</string>
    <string name="pref_title_low_bg_weight">Lavt BS-område vekt</string>
    <string name="openapsama_lower_ISFrange_weight_summary">Dette er vekten som tillegges når glukosen er under målet og svekker ISF og dermed potensielt reduserer insulinleveransen.\n\nStandardverdien 0.0 skrur effektivt av denne effekten.</string>
    <string name="pref_title_high_bg_weight">Høyt BS-område vekt</string>
    <string name="openapsama_higher_ISFrange_weight_summary">Dette er vekten som tillegges når glukosen er over målet og styrker ISF og dermed potensielt øker insulinleveransen.\n\nStandardverdien 0.0 skrur effektivt av denne effekten.</string>
    <string name="pref_title_smb_delivery_ratio_bg_range">SMB leveringsratio BS-område</string>
    <string name="openapsama_smb_delivery_ratio_bg_range_summary">Standardverdi: 0. Det lineært økende SMB-leveringsforholdet er kartlagt til glukoseområdet [target_bg, target_bg+bg_range].\nVed target_bg er SMB-forholdet smb_delivery_ratio_min, ved target_bg+bg_range er det smb_delivery_ratio_max.\nMed 0 er det lineært økende SMB-forholdet deaktivert og den faste smb_delivery_ratio brukes.</string>
    <string name="pref_title_pp_weight">Postprandial ISF-vekt</string>
    <string name="openapsama_pp_ISF_weight_summary">Dette er vekten som tillegges når glukosen stiger og som styrker ISF og dermed potensielt øker insulinleveransen.\n\nStandardverdien 0.0 skrur effektivt av denne effekten.</string>
    <string name="pref_title_dura_weight">Varighet ISF-vekt</string>
    <string name="openapsama_dura_ISF_weight_summary">Dette er vekten som tillegges over lengre forhøyet glukoseplatåer og som styrker ISF og dermed potensielt øker insulinleveransen.\n\nStandardverdien 0.0 skrur effektivt av denne effekten.</string>
    <string name="pref_title_smb_delivery_ratio">SMB leveringsratio</string>
    <string name="openapsama_smb_delivery_ratio_summary">Standardverdi: 0.5 Dette er en annen viktig OpenAPS sikkerhetsgrense, og angir hvilken andel av den totale insulin som kreves kan leveres som SMB. Dette er for å forhindre at personer kommer inn i farlig territorium ved å sette SMB-forespørsler fra omsorgspersonens telefon samtidig. Øk denne eksperimentelle verdien sakte og med forsiktighet.</string>
    <string name="pref_title_smb_delivery_ratio_min">SMB leveringsratio min</string>
    <string name="openapsama_smb_delivery_ratio_min_summary">Standardverdi: 0.5. Den nedre enden av en lineært økende ratio i stedet for den faste verdien ovenfor.</string>
    <string name="pref_title_smb_delivery_ratio_max">SMB leveringsratio maks</string>
    <string name="openapsama_smb_delivery_ratio_max_summary">Standardverdi: 0.5. Den øvre enden av en lineært økende ratio i stedet for den faste verdien ovenfor.</string>
    <string name="pref_title_smb_max_range_extension">SMB maks rekkeviddeforlengelse</string>
    <string name="openapsama_smb_max_range_extension_summary">Standardverdi: 1. Angir med hvilken faktor du kan overskride de vanlige 120 maxSMB/maxUAM minuttene. Øk denne eksperimentelle verdien sakte og med forsiktighet.</string>
    <!-- UnitDoubleKey: Overview preferences -->
