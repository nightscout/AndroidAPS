    <string name="pref_title_smb_delivery_ratio_max">Tỷ lệ SMB tối đa</string>
    <string name="openapsama_smb_delivery_ratio_max_summary">Giá trị mặc định: 0.5. Đây là giá trị giới hạn trên của một tỷ lệ tăng tuyến tính, thay vì là giá trị cố định như bên trên.</string>
    <string name="pref_title_smb_max_range_extension">Mở rộng phạm vi SMB tối đa</string>
